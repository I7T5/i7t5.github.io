---
import { getCollection } from 'astro:content';
import { COLLECTION } from '../../collections';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostItem from '../../layouts/PostItem.astro';
import Title from '../../components/Title.astro';
import ResearchItem from '../../layouts/ResearchItem.astro';
import HoverList from '../../components/HoverList.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection(COLLECTION.blog, ({ data }) => { return import.meta.env.PROD ? data.isDraft !== true : true; })
  const allResearch = await getCollection(COLLECTION.research)
  const postTags = allPosts.map((post: any) => post.data.tags).flat();
  const researchTags = allResearch.map((research: any) => research.data.tags).flat();
  const uniqueTags = [...new Set(postTags.concat(researchTags))];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post: any) => post.data.tags.includes(tag));
    const filteredResearch = allResearch.filter((research: any) => research.data.tags.includes(tag))
    return {
      params: { tag },
      // props: { posts: filteredPosts },
      // props: { projects: filteredProjects },
      props: { posts: filteredPosts, research: filteredResearch}
    };
  });
}

const { tag } = Astro.params;
// const { posts } = Astro.props;
// const { projects } = Astro.props;
const { posts, research } = Astro.props;

---
<BaseLayout pageTitle={tag}>
  <Title>#{tag}</Title>
  <HoverList>
    {posts.map((post: any) => <PostItem post={post}/>)}
    {research.map((item: any) => <ResearchItem research={item}/>)}
  </HoverList>
</BaseLayout>