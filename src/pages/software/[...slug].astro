---
import { getCollection, render } from 'astro:content';
import { COLLECTION } from '../../collections';
import SoftwareLayout from '../../layouts/SoftwareLayout.astro';

export async function getStaticPaths() {
  const software = await getCollection(COLLECTION.software, ({ data }) => { return import.meta.env.PROD ? data.enableLink === true : true; })
  return software.map(item => ({
    params: { slug: item.id }, props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---
<SoftwareLayout frontmatter={item.data}>
  <Content />
</SoftwareLayout>
